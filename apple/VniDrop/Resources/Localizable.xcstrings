    "storage_delete_transfers": {
      "comment": "Settings > Storage: button to delete all transfer records.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete all transfers"
          }
        },

          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Open source, publié sous licence Apache 2.0."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Open source, rilasciato con licenza Apache 2.0."
          }
        }
      }
    },
    "about_is_title": {
      "comment": "About screen: section heading for the 'What VniDrop is' list.",
      "extractionState": "manual",

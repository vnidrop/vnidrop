    "error_filesystem": {
      "comment": "Error: the selected files/folder could not be accessed.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop konnte nicht auf die ausgewählten Dateien oder den Ordner zugreifen. Überprüfen Sie die Berechtigungen und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VniDrop could not access the selected files or folder. Check permissions and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop no pudo acceder a los archivos o la carpeta seleccionados. Compruebe los permisos e inténtelo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop n’a pas pu accéder aux fichiers ou au dossier sélectionnés. Vérifiez les autorisations et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop non ha potuto accedere ai file o alla cartella selezionati. Controlli le autorizzazioni e riprovi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop kon geen toegang krijgen tot de geselecteerde bestanden of map. Controleer de machtigingen en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VniDrop nie mógł uzyskać dostępu do wybranych plików lub folderu. Sprawdź uprawnienia i spróbuj ponownie."
          }
        },

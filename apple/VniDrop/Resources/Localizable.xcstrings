    "about_tagline": {
      "comment": "About screen: short tagline under the app name.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Senden Sie Dateien direkt. Behalten Sie die Kontrolle darüber, wer sie empfängt."
          }
        },
        "en": {

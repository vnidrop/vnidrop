          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No es un servicio de sincronización ni de copia de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pas un service de synchronisation ou de sauvegarde."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Non è un servizio di sincronizzazione o di backup."
          }
        }
      }
    },

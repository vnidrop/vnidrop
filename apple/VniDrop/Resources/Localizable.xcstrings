      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Öffnen Sie eine VniDrop-Einladung, scannen Sie einen QR-Code oder halten Sie das Gerät an ein NFC-Tag."
          }
        },
        "en": {
          "stringUnit": {
